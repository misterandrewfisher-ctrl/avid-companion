{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Avid Companion",
  "version": "0.1.0",
  "identifier": "com.avidair.companion",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Avid Companion",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["../xppython3-plugin/PI_AvidBridge.py"],
    "shortDescription": "Avid Air Cargo Virtual companion",
    "longDescription": "Bridges the Avid VA website, OnAir, SayIntentions, SimBrief and X-Plane 12."
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/REPLACE_ME_OWNER/avid-companion/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxOUMzMzIyNDFBODlDNzIKUldSeW5LaEJJak9jNGJPSklCb01XTGdEWFo1Z2FaeGtQd3g3VlFaYVM4UlNBTWxwdFlSVmZDdzcK"
    }
  }
}

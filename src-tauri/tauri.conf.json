{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Avid Companion",
  "version": "0.2.8",
  "identifier": "com.avidair.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Avid Companion",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["../xppython3-plugin/PI_AvidBridge.py"],
    "shortDescription": "Avid Air Cargo Virtual companion",
    "longDescription": "Bridges the Avid VA website, OnAir, SayIntentions, SimBrief and X-Plane 12."
  }
}
